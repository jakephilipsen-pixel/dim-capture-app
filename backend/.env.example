DATABASE_URL=postgresql://gocold:gocold@localhost:5434/dimcapture
PORT=3005
NODE_ENV=development
FRONTEND_URL=http://localhost:5175
# CartonCloud OAuth2 client_credentials (module 16). From the parent gocold-wms-flow .env.
CC_CLIENT_ID=your_cc_client_id
CC_CLIENT_SECRET=your_cc_client_secret
CC_TENANT_ID=your_cc_tenant_id
# Customer to scope reads/writes to. Defaults to The Forage Company if unset.
CC_CUSTOMER_ID=d4810e1e-91ab-43ed-b68e-b72bd858b122
# Optional — overrides the default https://api.cartoncloud.com (used by tests/smoke)
CC_BASE_URL=
# Required to enable CC sync (POST /api/sync/cc) and seed (POST /api/admin/seed).
# If unset, both routes refuse with 503 (fail-closed — never allows an unauthenticated CC write).
# Generate a strong random value for production: openssl rand -hex 32
SYNC_SECRET=
