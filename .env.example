# dim-capture-app — production environment.
# Copy to `.env` (gitignored) and fill in the CC_* secrets before `docker compose up`.
# This file is consumed by the `backend` service in docker-compose.yml (env_file).

# ── Database ────────────────────────────────────────────────────────────────
# Inside the compose network the DB host is the service name `postgres` on the
# container port 5432 (NOT localhost:5434 — that's the host-published port used
# only when you run the backend outside Docker against docker-compose.local.yml).
# Credentials must match the postgres service in docker-compose.yml.
DATABASE_URL=postgresql://gocold:gocold@postgres:5432/dimcapture

# ── App ─────────────────────────────────────────────────────────────────────
# Node environment. Production for the deployed stack.
NODE_ENV=production
# Port the backend listens on inside its container (published 1:1 to the host).
PORT=3005
# Public origin of the app, used by the backend for CORS. Single-origin deploy,
# so this is the Caddy-fronted frontend URL.
FRONTEND_URL=http://dims.gocold.local

# ── CartonCloud API (OAuth2 client_credentials — secrets, fill these in) ─────
# From the parent gocold-wms-flow .env. Never commit the real values.
CC_CLIENT_ID=your_cc_client_id
CC_CLIENT_SECRET=your_cc_client_secret
# CartonCloud tenant UUID (path-scoped: /tenants/{id}/…).
CC_TENANT_ID=your_cc_tenant_id
# Customer to scope reads/writes to. Defaults to The Forage Company if unset.
CC_CUSTOMER_ID=d4810e1e-91ab-43ed-b68e-b72bd858b122
# Optional override of the CC base URL. Leave blank to use the default
# https://api.cartoncloud.com (set only for tests/mocks).
CC_BASE_URL=
